# Block direct HTTP access to sensitive files and dirs.

# ── Block dotfiles (.git, .gitignore, .env, etc.) ───────────────────────────
RedirectMatch 404 ^/?\.(?!well-known)

# ── Block sensitive file extensions at any depth ────────────────────────────
<FilesMatch "\.(sql|md|lock|toml|env|log|bat|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ── Block specific composer files and metadata ──────────────────────────────
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|schema\.sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ── Block sensitive directories ─────────────────────────────────────────────
RedirectMatch 404 ^/?(vendor|scraper|tools|data/ai-cache)(/|$)

# ── Block scraper-output JSON (data/deals-*.json and data/deals.json) ──────
# The frontend only reads data/deals-frontend.json directly; everything else
# in data/ is internal/server-side.
RedirectMatch 404 ^/?data/(deals-(ah|jumbo|lidl|aldi|plus|dirk)|deals)\.json$
